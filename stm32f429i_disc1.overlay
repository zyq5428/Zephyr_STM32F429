/* 如果你也用到了 dma1，同样需要修正 */
// &dma1 {
//     compatible = "st,stm32-dma-v2";
//     #dma-cells = <3>;
//     status = "okay";
// };

/* 强制纠正 DMA 控制器的属性，解决 #dma-cells 不匹配问题 */
&dma2 {
    compatible = "st,stm32-dma-v2"; /* 必须指定为 v2 */
    #dma-cells = <3>;               /* 必须强制设为 3 */
    status = "okay";
};

/* 配置串口 */
&usart1 {
    /* 现在这里的 3 个数字就能和上面的 #dma-cells = <3> 匹配上了 */
    dmas = <&dma2 7 4 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_HIGH)>,
           <&dma2 2 4 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_HIGH)>;
    dma-names = "tx", "rx";
    status = "okay";
};

/* 修正 SPI5 的引脚分配，移除不需要的 PF6 */
&spi5 {
    pinctrl-0 = <&spi5_sck_pf7 &spi5_miso_pf8 &spi5_mosi_pf9>;
    pinctrl-names = "default";
    status = "okay";
    /* 这里定义两个片选，第一个给屏幕(Index 0)，第二个给MEMS(Index 1) */
    cs-gpios = <&gpioc 2 GPIO_ACTIVE_LOW>, <&gpioc 1 GPIO_ACTIVE_LOW>;
};

// Zephyr 官方的 ILI9341 驱动绑定文件（Binding）中没有定义 te-gpios 这个属性
// &ili9341 {
// 	te-gpios = <&gpiod 11 GPIO_ACTIVE_HIGH>;
// };

&fmc {
	status = "okay";
    sdram {
        status = "okay";
        power-up-delay = <100>;
        num-auto-refresh = <8>;      /* 初始化标准流程：8次自动刷新 */
        mode-register = <0x0231>;    /* 设置 Burst=2, CAS=3 (对应下面的CAS_3) */
        refresh-rate = <1386>;       /* 基于 84MHz 计算出的 64ms/4096行刷新率 */

        bank@1 {
            reg = <1>;               /* 物理连接：SDRAM 片选挂在 Bank 2 (SDNE1) */

            st,sdram-control = <STM32_FMC_SDRAM_NC_8
                                STM32_FMC_SDRAM_NR_12
                                STM32_FMC_SDRAM_MWID_16
                                STM32_FMC_SDRAM_NB_4
                                STM32_FMC_SDRAM_CAS_3
                                STM32_FMC_SDRAM_SDCLK_PERIOD_2
                                STM32_FMC_SDRAM_RBURST_DISABLE
                                STM32_FMC_SDRAM_RPIPE_1>;

            /* 对应 CubeMX 参数转换 (单位为 SDCLK 周期) */
            /* [TMRD, TXSR, TRAS, TRC, TWR, TRP, TRCD] */
            /* TRAS 说明：CubeMX 的 8 HCLK 换算为 4 SDCLK，寄存器填 4-1=3 或更稳的 4 */
            st,sdram-timing = <2 7 4 7 2 2 2>;
        };
    };
};

// 不修改这个也能正常使用
// &ili9341 {
// 	disctrl = [0A A7 27 04];
// };

&stmpe811 {
    /* 使用这个关键字来删除官方文件里定义的属性 */
    /delete-property/ inverted-y;

    /* 优化触摸参数 */
    tracking-index = <16>;           /* 降低数值，让小幅移动更灵敏 */
};
